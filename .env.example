# rtx5090-vllm — local configuration
#
# Copy to .env (`cp .env.example .env`) and uncomment/edit what you need.
# run.sh sources .env automatically on startup. Lines are KEY=value; `#` starts
# a comment. Real environment variables take precedence over .env, so
# `BIND_CIDR=… ./run.sh` still overrides the file.

# ─── Network binding (read by run.sh) ───────────────────────────────────────

# Bind the published API port to a single address. Default: 0.0.0.0 (all
# interfaces — reachable from any network that can route here). Set to
# 127.0.0.1 for localhost-only, or a specific NIC address.
#HOST_IP=127.0.0.1

# Host port for the OpenAI-compatible API. Default: 8080.
#HOST_PORT=8080

# Restrict vLLM to ONE network: run.sh finds this host's address inside the
# subnet and binds the port only there, so the API is reachable only from that
# network (e.g. a WireGuard VPN). HOST_IP (if set) overrides this.
#BIND_CIDR=10.200.0.0/24

# ─── HuggingFace (read when run.sh downloads weights) ───────────────────────

# Token for authenticated/faster downloads (avoids unauthenticated rate limits
# and gated repos). Get one at https://huggingface.co/settings/tokens
#HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Test / benchmark helpers (test-*.sh, bench-ctx.sh) ─────────────────────
# These scripts read from the shell environment, not from .env directly. To use
# them with these values, load .env into your shell first:
#     set -a; . ./.env; set +a

# API endpoint the test scripts hit. Default: http://localhost:8080/v1
# (when bound to a VPN, point this at that address, e.g. the BIND_CIDR host IP).
#ENDPOINT=http://10.200.0.27:8080/v1

# Max tokens generated in test completions. Default: 2000.
#MAX_TOKENS=2000

# Seconds to wait for the server to become ready in bench-ctx.sh. Default: 300.
#TIMEOUT=300
